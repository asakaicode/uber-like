generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  RESTAURANT
  DRIVER
}

enum OrderStatus {
  PENDING_RESTAURANT
  RESTAURANT_REJECTED
  QUEUED
  OFFERED
  DRIVER_ASSIGNED
  PICKED_UP
  DELIVERED
  COMPLETED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  DELIVERED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customerProfile CustomerProfile?
  restaurant      Restaurant?
  driverProfile   DriverProfile?
}

model CustomerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

model Restaurant {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  lat       Float
  lng       Float
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItems MenuItem[]
  orders    Order[]
}

model MenuItem {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  price        Int
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model DriverProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  isOnline  Boolean  @default(false)
  rating    Float    @default(5.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations DriverLocation[]
  offers    DriverOffer[]
  deliveries Delivery[]
}

model DriverLocation {
  id        String   @id @default(cuid())
  driverId  String
  lat       Float
  lng       Float
  heading   Float    @default(0)
  createdAt DateTime @default(now())

  driver DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, createdAt])
}

model Order {
  id              String      @id @default(cuid())
  customerId      String
  restaurantId    String
  status          OrderStatus @default(PENDING_RESTAURANT)
  totalAmount     Int
  deliveryAddress String
  deliveryLat     Float
  deliveryLng     Float
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer   CustomerProfile @relation(fields: [customerId], references: [id])
  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  items      OrderItem[]
  delivery   Delivery?
  rating     Rating?

  @@index([customerId, createdAt, id])
  @@index([restaurantId, createdAt, id])
  @@index([status])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Int

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

model Delivery {
  id                   String         @id @default(cuid())
  orderId              String         @unique
  driverId             String?
  status               DeliveryStatus @default(PENDING)
  distanceToRestaurant Float?
  distanceToCustomer   Float?
  totalDistance        Float?
  estimatedMinutes     Int?
  reward               Int?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  order  Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver DriverProfile? @relation(fields: [driverId], references: [id])
  offers DriverOffer[]
}

model DriverOffer {
  id         String      @id @default(cuid())
  deliveryId String
  driverId   String
  status     OfferStatus @default(PENDING)
  priority   Float
  expiresAt  DateTime
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  delivery Delivery      @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  driver   DriverProfile @relation(fields: [driverId], references: [id])

  @@index([driverId, createdAt, id])
  @@index([deliveryId, status])
}

model Rating {
  id        String   @id @default(cuid())
  orderId   String   @unique
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
